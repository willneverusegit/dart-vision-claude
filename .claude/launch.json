{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dart-vision-web",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "src.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "pytest",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "pytest", "-q"]
    },
    {
      "name": "pytest-coverage",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "pytest", "--cov=src", "-q"]
    },
    {
      "name": "diagnostics",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "src.diagnose"]
    }
  ]
}
