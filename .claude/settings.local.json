{
  "permissions": {
    "allow": [
      "Bash(python -m pytest:*)",
      "Bash(python -m src:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(python:*)",
      "Bash(.venv/Scripts/python.exe -m pytest:*)",
      "Bash(.venv/Scripts/python.exe -m ruff:*)",
      "Bash(.venv/Scripts/python.exe -c:*)",
      "Bash(.venv/Scripts/python.exe scripts/:*)",
      "Bash(PYTHONIOENCODING=utf-8 python:*)",
      "Bash(ruff check:*)",
      "Bash(node -c:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git -C:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git push:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(xargs:*)",
      "Bash(bc)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(claude mcp:*)",
      "Bash(for:*)",
      "Bash(do:*)",
      "Bash(done)",
      "mcp__Claude_Preview__preview_start",
      "mcp__scheduled-tasks__list_scheduled_tasks",
      "Skill(commit-commands:commit:*)",
      "Skill(claude-md-management:revise-claude-md:*)",
      "Read(//c/Users/domes/OneDrive/Desktop/dart-vision-claude/**)",
      "Read(//c/Users/domes/.claude/plugins/self-improving-agent/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ARGS=\"$CLAUDE_TOOL_INPUT\"; if echo \"$ARGS\" | grep -q \"git commit\"; then bash scripts/pre_commit_check.sh; fi'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=\"$CLAUDE_FILE_PATH\"; if [[ \"$FILE\" == *.py ]]; then ruff check --fix \"$FILE\" 2>/dev/null; fi'"
          },
          {
            "type": "command",
            "command": "bash -c 'FILE=\"$CLAUDE_FILE_PATH\"; if [[ \"$FILE\" == *.js ]]; then node -c \"$FILE\" 2>&1; fi'"
          }
        ]
      }
    ]
  }
}
